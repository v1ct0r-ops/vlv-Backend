# Base de Datos (cambia el password por uno propio, no uses este valor)
DATABASE_URL=postgresql://gas_user:CAMBIA_ESTE_PASSWORD@db:5432/gas_db
DB_USER=gas_user
DB_PASSWORD=CAMBIA_ESTE_PASSWORD
DB_NAME=gas_db
DB_HOST=db
DB_PORT=5434

# FastAPI
API_TITLE=Inventario de Gas
DEBUG=False
LOG_LEVEL=info

# Adminer
ADMINER_PORT=8080

CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth / JWT
# Genera SECRET_KEY con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTE_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Usuario admin inicial (seed). Si faltan, no se crea admin automático.
SEED_ADMIN_EMAIL=admin@tuempresa.cl
SEED_ADMIN_PASSWORD=CAMBIA_ESTA_CLAVE